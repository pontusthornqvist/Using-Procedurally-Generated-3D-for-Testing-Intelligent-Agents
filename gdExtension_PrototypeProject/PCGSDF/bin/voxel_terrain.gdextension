[configuration]

entry_symbol = "voxel_terrain_library_init"
compatibility_minimum = "4.2"

[libraries]

windows.debug.x86_64 = "res://bin/voxel_terrain.windows.template_debug.x86_64.dll"
windows.release.x86_64 = "res://bin/voxel_terrain.windows.template_release.x86_64.dll"
linux.debug.x86_64 = "res://bin/voxel_terrain.linux.template_debug.x86_64.so"
linux.release.x86_64 = "res://bin/voxel_terrain.linux.template_release.x86_64.so"
macos.debug = "res://bin/voxel_terrain.macos.template_debug.framework"
macos.release = "res://bin/voxel_terrain.macos.template_release.framework"